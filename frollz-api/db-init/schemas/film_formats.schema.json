{
  "rule": {
    "$schema": "http://json-schema.org/draft-07/schema",
    "type": "object",
    "properties": {
      "formFactor": {
        "type": "string",
        "enum": ["Roll", "Sheet", "Instant", "100ft Bulk", "400ft Bulk"]
      },
      "format": {
        "type": "string",
        "enum": ["35mm", "110", "Mini", "Wide", "Square", "120", "220", "4x5", "8x10", "I-Type", "600", "SX-70", "GO"]
      },
      "createdAt": {
        "type": "string",
        "format": "date-time"
      },
      "updatedAt": {
        "type": "string",
        "format": "date-time"
      }
    },
    "required": ["formFactor", "format"],
    "additionalProperties": false
  },
  "level": "strict",
  "message": "Document does not conform to the film_formats schema."
}
