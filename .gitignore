# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build output ──────────────────────────────────────────────────────────────
apps/api/dist/
apps/web/.next/

# ── SQLite development database ───────────────────────────────────────────────
apps/api/dev.db

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
# Prevent tsc composite-mode from committing emitted files into src/
apps/web/**/*.js
apps/web/**/*.d.ts

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Claude Code — commit skills + agents, ignore everything else ──
.claude/settings.local.json
apps/api/coverage
apps/web/coverage
**/*/*.sqlite.json
**/frollz-api/dev.db
.turbo/**
**/.turbo/**

# ── codebase-memory MCP tool output (generated, not for version control) ──────
.codebase-memory/*.sqlite
**/*.sqlite
**/*/.env

# ── playwright-bdd generated test wrappers (generated at runtime) ──────
**/.features-gen/


report.html
apps/api/src/infrastructure/migrations/.snapshot-frollz2.sqlite.json
apps/api/src/infrastructure/migrations/.snapshot-test.sqlite.json
report.json
trace-mobile-film.json

# --- Ignore generated files ---

**/*.js.map
**/*.d.ts

# -- ignore java script files, except for the eslint config
**/*.js
!packages/eslint-config/eslint.config.js
apps/api/src/infrastructure/migrations/.snapshot-memory.json
apps/web/test-results/
apps/web/tsconfig.tsbuildinfo
