{
  "extends": "../../packages/typescript-config/node.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": true,
    "noEmit": false,
    "lib": [
      "ES2022",
      "decorators.legacy"
    ],
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": "."
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/__tests__/**",
    "dist",
    "node_modules"
  ]
}